# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
# For local development, use the DEV Supabase project credentials.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL
# Used for auth redirects, QR codes, and public links.
# Centralised in lib/config.ts via getSiteUrl().
#
# Environments:
#   Localhost:   http://localhost:3000      (fallback if not set)
#   Dev:         https://dev.fanflet.com    (set in Vercel Preview env vars)
#   Production:  https://fanflet.com        (set in Vercel Production env vars)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email)
# Sign up at https://resend.com and create an API key.
# Used for subscriber confirmation emails and admin notification emails.
# Leave blank to disable email sending (graceful degradation).
RESEND_API_KEY=
# Optional: custom from address. Requires a verified domain in Resend.
# Default: "Fanflet <onboarding@resend.dev>" (Resend testing domain, limited recipients)
RESEND_FROM=

# Supabase service role key (server-only)
# Required for admin notifications (querying admin preferences, resolving admin emails).
# Get from Supabase dashboard: Settings > API > service_role key.
# NEVER expose in NEXT_PUBLIC_ env vars.
SUPABASE_SERVICE_ROLE_KEY=

# Twilio (SMS Bookmark feature)
# Sign up at https://twilio.com and buy a phone number.
# Leave blank to disable SMS sending (bookmarks still tracked).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Supabase JWT secret (server-only)
# Required for MCP authentication (user-scoped clients) and impersonation.
# Get from Supabase dashboard: Settings > API > JWT Secret.
# NEVER expose in NEXT_PUBLIC_ env vars.
SUPABASE_JWT_SECRET=

# Google Tag Manager (optional)
# If set, GTM script is injected into the page head.
# If unset, no analytics tracking is loaded.
NEXT_PUBLIC_GTM_ID=

# Cloudflare Turnstile (Enterprise contact form CAPTCHA)
# Optional. Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# If set, the Enterprise contact modal requires Turnstile before submit.
# If unset, the form works without CAPTCHA (rate limit still applies).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-only; never expose in NEXT_PUBLIC_ env vars.
TURNSTILE_SECRET_KEY=
