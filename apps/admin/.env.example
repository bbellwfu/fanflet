# Supabase (same project as web app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-only, never NEXT_PUBLIC_)
# Required for dashboard features that bypass RLS (e.g. listing all accounts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Main web app URL — used for links to public fanflet pages and impersonation redirects.
# Local dev:  http://localhost:3000
# Production: https://fanflet.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin portal URL — used for OAuth redirects (Google sign-in callback).
# Local dev:  http://localhost:3001
# Production: https://admin.fanflet.com
# Add the callback URL to Supabase Auth > URL Configuration > Redirect URLs:
#   http://localhost:3001/auth/callback
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Supabase JWT secret — used for signing impersonation JWTs.
# Find in Supabase Dashboard > Settings > API > JWT Secret.
# Server-only — never prefix with NEXT_PUBLIC_.
SUPABASE_JWT_SECRET=your-jwt-secret

# Anthropic API key (server-only)
# Required for AI-powered demo environment generation (Claude Haiku).
# Get from https://console.anthropic.com > API Keys.
# Leave blank to disable demo AI generation.
ANTHROPIC_API_KEY=

# Email provider (server-only, optional)
# Which provider to use for platform communications (release announcements).
# Default: "resend" if not set.
PLATFORM_EMAIL_PROVIDER=resend

# Resend (transactional email for platform communications)
# Required if PLATFORM_EMAIL_PROVIDER=resend (the default).
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=
RESEND_FROM=

# Optional (local dev only): if you see "unable to get local issuer certificate" in the
# terminal when the Edge middleware talks to Supabase, run the dev server with:
#   NODE_TLS_REJECT_UNAUTHORIZED=0 npm run dev:admin
# Do not use in production.
