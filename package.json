{
  "name": "fanflet-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@fanflet/web",
    "dev:admin": "turbo dev --filter=@fanflet/admin",
    "build:web": "turbo build --filter=@fanflet/web",
    "build:admin": "turbo build --filter=@fanflet/admin",
    "db:login": "npx supabase login",
    "db:link": "npx supabase link",
    "db:migration:new": "npx supabase migration new",
    "db:push": "npx supabase db push",
    "db:status": "npx supabase migration list",
    "db:types": "npx supabase gen types typescript --linked > packages/types/src/database.ts",
    "test": "turbo test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "playwright": "^1.58.2",
    "supabase": "^2.76.9",
    "turbo": "^2"
  },
  "packageManager": "npm@10.9.2"
}
